REM ===========================================================================
REM A collection of string values that are used to find common paths.
REM
REM The contents of this file are licensed to you by Ryan Singleton under the
REM MIT license.
REM ===========================================================================

Include MAPPATH_SCRIPTS + "Common/CoreFunctions.cod"

REM ===========================================================================
REM # Purpose
REM Removes the slash at the start of the path, if there is one, to make path
REM concatenation more predicatable.
REM 
REM # Inputs
REM - path: The provided path value to remove a leading slash from.
REM 
REM # Returns
REM The without a leading slash.
REM ===========================================================================
Function TrimStartSlashes(path)
    Dim result = path
    If StartsWith(path, "/*") Or StartsWith(path, "\*") Then
        result = Right(path, Len(path) - 1)
    End If
    Return result
End Function

REM ===========================================================================
REM # Purpose
REM Gets a path within the MAPPATH_SCRIPTS, or the configuraiton scripts 
REM folder.
REM 
REM # Inputs
REM - path: The relative path under the scripts folder to locate.
REM 
REM # Returns
REM The fully formed subpath under the scripts folder.
REM ===========================================================================
Function ScriptPath(path)
    Return MAPPATH_SCRIPTS + TrimStartSlashes(path)
End Function

REM ===========================================================================
REM # Purpose
REM Gets the root path of the common folder for VBS files that come with this
REM repo.
REM 
REM # Returns
REM The fully formed root path of the VBS folder.
REM ===========================================================================
Function VbScripts()
    Return MAPPATH_SCRIPTS + "Common\VB Scripts\"
End Function

REM ===========================================================================
REM # Purpose
REM Gets a path within the common folder for VBS files that come with this repo.
REM 
REM # Inputs
REM - path: The relative path under the VBS folder to locate.
REM 
REM # Returns
REM The fully formed subpath under the VBS folder.
REM ===========================================================================
Function VbScriptPath(path)
    Return VbScripts() + TrimStartSlashes(path)
End Function

REM ===========================================================================
REM # Purpose
REM Gets the root path of the typical temporary folder for scripts to use.
REM 
REM # Returns
REM The fully formed root path of the temporary folder.
REM ===========================================================================
Function TempRoot()
    Return "C:\Windows\Temp\FabScripts\"
End Function

REM ===========================================================================
REM # Purpose
REM Gets a path within the temorary folder for scripts to use.
REM 
REM # Inputs
REM - path: The relative path under the temporary folder to locate.
REM 
REM # Returns
REM The fully formed subpath under the temporary folder.
REM ===========================================================================
Function TempPath(path)
    Return TempRoot() + TrimStartSlashes(path)
End Function

REM ===========================================================================
REM # Purpose
REM Gets the path to the dynamic functions that are created by our VBS script.
REM 
REM # Returns
REM The fully formed path to the dynamic functions COD script, generated by
REM VBS.
REM ===========================================================================
Function DynamicScriptPath()
    Return TempPath("DynamicFunctions.cod")
End Function